{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github-mcp-server": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GH_TOKEN}"
      }
    },
    "azure-devops": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@azure-devops/mcp",
        "<your-org>"
      ],
      "enabled": false
    }
  },
  "permission": "allow",
  "instructions": [
    "~/.atomic/AGENTS.md"
  ]
}
